{
  "compilerOptions": {
    "target": "ES2024",
    "module": "ESNext",
    "moduleResolution": "Bundler",
    "allowSyntheticDefaultImports": true,
    "esModuleInterop": true,
    "strict": true,
    "ignoreDeprecations": "6.0",
    "noUncheckedIndexedAccess": true,
    "exactOptionalPropertyTypes": true,
    "forceConsistentCasingInFileNames": true,
    "skipLibCheck": true,
    "resolveJsonModule": true,
    "verbatimModuleSyntax": true,
    "types": ["bun-types"],
    "baseUrl": ".",
    "paths": {
      "@onlydoge/shared-kernel": ["./packages/shared-kernel/src/index.ts"],
      "@onlydoge/api": ["./apps/api/src/index.ts"],
      "@onlydoge/indexer-app": ["./apps/indexer/src/index.ts"],
      "@onlydoge/platform": ["./packages/platform/src/index.ts"],
      "@onlydoge/access-control": ["./packages/modules/access-control/src/index.ts"],
      "@onlydoge/network-catalog": ["./packages/modules/network-catalog/src/index.ts"],
      "@onlydoge/entity-labeling": ["./packages/modules/entity-labeling/src/index.ts"],
      "@onlydoge/explorer-query": ["./packages/modules/explorer-query/src/index.ts"],
      "@onlydoge/investigation-query": ["./packages/modules/investigation-query/src/index.ts"],
      "@onlydoge/indexing-pipeline": ["./packages/modules/indexing-pipeline/src/index.ts"]
    }
  },
  "include": ["apps/**/*.ts", "packages/**/*.ts", "tests/**/*.ts", "drizzle.config.ts"]
}
