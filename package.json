{
  "name": "onlydoge",
  "private": true,
  "type": "module",
  "packageManager": "bun@1.3.6",
  "workspaces": [
    "apps/*",
    "packages/*",
    "packages/modules/*"
  ],
  "scripts": {
    "start": "bun run apps/onlydoge/src/index.ts",
    "dev": "bun run apps/onlydoge/src/index.ts",
    "dev:both": "bun run apps/onlydoge/src/index.ts --mode=both",
    "dev:http": "bun run apps/onlydoge/src/index.ts --mode=http",
    "dev:indexer": "bun run apps/onlydoge/src/index.ts --mode=indexer",
    "runsheet:dogecoin": "bun run scripts/dogecoin-runsheet.ts",
    "health:indexer": "bun run scripts/indexer-health.ts",
    "test": "vitest run",
    "test:watch": "vitest",
    "lint": "biome check .",
    "typecheck": "bunx tsc --noEmit -p tsconfig.json",
    "format": "biome format --write .",
    "ci": "bun run lint && bun run typecheck && bun run test",
    "docker:local:up": "docker compose --env-file .env.local -f docker-compose.local.yml up --build",
    "docker:local:down": "docker compose --env-file .env.local -f docker-compose.local.yml down --remove-orphans",
    "docker:local:reset": "docker compose --env-file .env.local -f docker-compose.local.yml down -v --remove-orphans",
    "docker:local:logs": "docker compose --env-file .env.local -f docker-compose.local.yml logs -f",
    "docker:prod:up": "docker compose --env-file .env.production -f docker-compose.prod.yml up -d --build",
    "docker:prod:down": "docker compose --env-file .env.production -f docker-compose.prod.yml down --remove-orphans",
    "docker:prod:logs": "docker compose --env-file .env.production -f docker-compose.prod.yml logs -f",
    "image:builder:init": "sh ./scripts/push-image.sh --init-only",
    "image:push": "sh ./scripts/push-image.sh",
    "deploy:docker": "bun run scripts/deploy-docker.ts",
    "deploy:once": "bun run scripts/deploy-once.ts"
  },
  "dependencies": {
    "@aws-sdk/client-s3": "3.1015.0",
    "@clickhouse/client": "1.18.2",
    "@elysiajs/openapi": "1.4.14",
    "@libsql/client": "0.17.2",
    "commander": "14.0.3",
    "dotenv": "17.3.1",
    "drizzle-orm": "0.45.1",
    "elysia": "1.4.14",
    "mysql2": "3.20.0",
    "pg": "8.20.0",
    "pino": "10.3.1"
  },
  "devDependencies": {
    "@onlydoge/api": "workspace:*",
    "@onlydoge/indexing-pipeline": "workspace:*",
    "@onlydoge/platform": "workspace:*",
    "@onlydoge/shared-kernel": "workspace:*",
    "@biomejs/biome": "2.4.8",
    "@types/pg": "^8.15.6",
    "bun-types": "1.3.11",
    "drizzle-kit": "0.31.10",
    "fallow": "^2.56.0",
    "typescript": "6.0.2",
    "vitest": "4.1.1"
  }
}
