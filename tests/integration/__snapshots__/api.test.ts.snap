    "/v1/info/": {
      "get": {
        "description": "Looks up a blockchain address or an entity id and returns known balances, linked sources, tags, and related entities. Example searches: \`?q=DTestAddress123\`, \`?q=ent_exampleentity\`.",
        "operationId": "getV1Info",
        "parameters": [
          {
            "in": "query",
            "name": "q",
            "required": false,
            "schema": {
              "description": "Address or entity id to investigate, for example \`DTestAddress123\` or \`ent_exampleentity\`.",
              "examples": [
                "DTestAddress123",
                "ent_exampleentity",
              ],
              "type": "string",
            },
          },
        ],
        "responses": {
          "200": {
            "content": {
              "application/json": {
                "examples": {
                  "addressLookup": {
                    "summary": "Address lookup with entity and risk context",
                    "value": {
                      "addresses": [
                        "DTestAddress123",
                      ],
                      "assets": [
                        {
                          "balance": "2500000000",
                          "network": "net_dogecoin",
                        },
                      ],
                      "entities": [
                        {
                          "data": {},
                          "description": "Tracked counterparty",
                          "id": "ent_exampleentity",
                          "name": "Example Entity",
                          "tags": [
                            "tag_sanctions",
                          ],
                        },
                      ],
                      "networks": [
                        {
                          "chainId": 0,
                          "id": "net_dogecoin",
                          "name": "Dogecoin Mainnet",
                        },
                      ],
                      "risk": {
                        "level": "high",
                        "reasons": [
                          "entity",
                          "source",
                        ],
                      },
                      "sources": [
                        {
                          "entity": "ent_sourceentity",
                          "from": "DSourceWallet456",
                          "hops": 2,
                          "network": "net_dogecoin",
                          "to": "DTestAddress123",
                        },
                      ],
                      "tags": [
                        {
                          "id": "tag_sanctions",
                          "name": "Sanctions",
                          "riskLevel": "high",
                        },
                      ],
                      "tokens": [],
                    },
                  },
                },
              },
            },
            "description": "Investigation result for the supplied address or entity.",
          },
          "400": {
            "content": {
              "application/json": {
                "examples": {
                  "missingQuery": {
                    "summary": "Missing q parameter",
                    "value": {
                      "error": "missing input params",
                    },
                  },
                },
              },
            },
            "description": "The query string is missing.",
          },
        },
        "security": [
          {
            "ApiTokenAuth": [],
          },
        ],
      },
    },
